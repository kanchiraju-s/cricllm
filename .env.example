# Google Generative AI API key (hosted Gemini API — required)
GOOGLE_API_KEY=your-gemini-api-key-here

# Pinecone API key (hosted vector store — required)
# Free tier: sign up at https://app.pinecone.io, no credit card needed
PINECONE_API_KEY=your-pinecone-api-key-here

# Embedding model (hosted only, no local models)
# text-embedding-004 was retired by Google; gemini-embedding-001 is the GA replacement
CRICLLM_EMBEDDING_MODEL=models/gemini-embedding-001
# Must match gemini-embedding-001's actual output size — also used as the
# Pinecone index's dimension when it gets created.
CRICLLM_EMBEDDING_DIMENSION=3072

# Chunk sizing (approximate tokens, tiktoken cl100k_base proxy)
CRICLLM_MIN_CHUNK_TOKENS=400
CRICLLM_MAX_CHUNK_TOKENS=700
CRICLLM_HARD_MAX_CHUNK_TOKENS=1400

# Gemini's embedContent endpoint rejects input above ~2048 tokens. A code/table/
# list block bigger than this would fail the embed call no matter how it's
# retried, so it gets force-split as a last resort instead of kept whole.
CRICLLM_MAX_EMBEDDING_INPUT_TOKENS=2048

# Embedding request batching / resilience
CRICLLM_EMBED_BATCH_SIZE=32
CRICLLM_MAX_RETRIES=6
CRICLLM_RETRY_MIN_SECONDS=1
CRICLLM_RETRY_MAX_SECONDS=60

# Whether to run langchain-experimental SemanticChunker on oversized prose
# blocks (costs extra embedding calls). Falls back to a recursive splitter
# when False or when the package/API is unavailable.
CRICLLM_USE_SEMANTIC_CHUNKING=true

# Storage locations
CRICLLM_CACHE_DB=.cache/cricllm_cache.sqlite3
CRICLLM_LOG_DIR=logs
CRICLLM_DEAD_LETTER_DIR=logs/dead_letter

# Pinecone index name (lowercase alphanumerics + hyphens only — Pinecone's
# own naming restriction). Created automatically on first run if missing.
CRICLLM_PINECONE_INDEX_NAME=cricllm-icc-laws

# Query-time only (scripts/ask.py): chat model that answers from retrieved chunks
CRICLLM_GENERATION_MODEL=gemini-2.5-flash
CRICLLM_RETRIEVAL_TOP_K=5
